# ==========================================
# Project Forge - 環境変数設定ファイル
# ==========================================
# このファイルをコピーして .env にリネームし、
# 実際の値を設定してください。
# .env は絶対に Git にコミットしないでください！

# ------------------------------------------
# GitHub CI/CD 連携（--pr フラグ使用時に必要）
# ------------------------------------------
# GitHub Personal Access Token
# 取得方法: GitHub → Settings → Developer settings
#         → Personal access tokens → Tokens (classic)
#         → Generate new token → "repo" スコープを選択
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 対象リポジトリ（"owner/repo-name" 形式）
GITHUB_REPO=your-org/your-repo

# ------------------------------------------
# Gemini API（将来的にSDK移行時に使用）
# ------------------------------------------
# 現在は gemini CLI の認証を使用するため不要
# GEMINI_API_KEY=your-api-key-here
